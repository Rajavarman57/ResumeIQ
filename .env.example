# ResumeIQ Configuration Example
# Copy this file to appropriate locations and adjust settings

# ============================================
# BACKEND CONFIGURATION
# ============================================
# File: backend/src/main/resources/application.properties

# Server Settings
SERVER_PORT=8080
CONTEXT_PATH=/api

# H2 Database (Local Development) - DEFAULT
DATASOURCE_URL=jdbc:h2:file:./data/resumeiq-demo
DATASOURCE_DRIVER=org.h2.Driver
DATASOURCE_USERNAME=sa
DATASOURCE_PASSWORD=

# MySQL Database (Production)
# DATASOURCE_URL=jdbc:mysql://localhost:3306/resumeiq?createDatabaseIfNotExist=true
# DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver
# DATASOURCE_USERNAME=root
# DATASOURCE_PASSWORD=your_secure_password

# File Upload Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# JPA/Hibernate Settings
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=true

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# File: frontend/server.js

# Server Settings
FRONTEND_PORT=5173
API_BASE_URL=http://localhost:8080/api

# ============================================
# DEVELOPMENT ENVIRONMENT
# ============================================

# Java Version Required: 23+
JAVA_HOME=/path/to/java/23

# Maven (if not using wrapper)
M2_HOME=/path/to/maven

# Node Version Required: 16+
NODE_VERSION=18+

# ============================================
# TROUBLESHOOTING NOTES
# ============================================

# For Windows Users:
# - Use setup.cmd or setup.ps1 to start both services
# - Ensure ports 8080 and 5173 are available
# - Run PowerShell as Administrator if permission issues occur

# For macOS/Linux Users:
# - Use terminal to run: chmod +x setup.sh && ./setup.sh (when available)
# - Check firewall settings for ports 8080 and 5173

# For Docker (future):
# - Docker configuration files can be added for containerized deployment
# - Simplifies production deployment and environment consistency
